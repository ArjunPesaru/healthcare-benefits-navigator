# Copy this file to .env and fill in your values before running setup.py or app.py
# .env is listed in .gitignore and will never be committed.

# Mistral API key — required for the LLM answer generation step.
# Get your key at: https://console.mistral.ai/api-keys
# Model used: mistral-small-latest (see config.py → MISTRAL_MODEL)
MISTRAL_API_KEY=your_mistral_api_key_here
